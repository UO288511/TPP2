<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER">
		<attributes>
			<attribute name="module" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="src" path="src"/>
	<classpathentry kind="lib" path="lib/reactive-streams-1.0.4.jar"/>
	<classpathentry kind="lib" path="lib/rxjava-3.1.10.jar">
		<attributes>
			<attribute name="javadoc_location" value="jar:platform:/resource/RxJava/lib/rxjava-3.1.10-javadoc.jar!/"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="output" path="bin"/>
</classpath>
